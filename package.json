{
  "name": "moltpost",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "npm run test:broker && npm run test:client",
    "test:broker": "vitest run --config test/vitest.broker.config.js",
    "test:client": "vitest run --config test/vitest.client.config.js",
    "test:e2e": "vitest run --config test/vitest.e2e.config.js",
    "test:all": "npm run test && npm run test:e2e",
    "test:watch": "vitest --config test/vitest.broker.config.js"
  },
  "devDependencies": {
    "vitest": "^1.0.0",
    "wrangler": "^4.76.0"
  }
}
